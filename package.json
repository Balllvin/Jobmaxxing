{
  "name": "jobmaxxing",
  "description": "Local companion tools for the native Jobmaxxing macOS app.",
  "type": "module",
  "bin": {
    "jobmaxxing": "./src/cli.ts"
  },
  "scripts": {
    "api": "tsx src/server.ts",
    "build": "./script/build_and_run.sh --verify",
    "typecheck:strict": "tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "test": "vitest run",
    "lint": "eslint .",
    "mcp": "tsx src/mcp.ts",
    "jm": "tsx src/cli.ts",
    "smoke": "tsx scripts/smoke.ts",
    "native:test": "scripts/test_native.sh",
    "clean:check": "scripts/check_clean_repo.sh"
  },
  "keywords": [
    "jobs",
    "agents",
    "mcp",
    "local-first",
    "career"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
